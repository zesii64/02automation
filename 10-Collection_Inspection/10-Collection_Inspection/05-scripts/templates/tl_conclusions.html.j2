{# TL Conclusions Jinja2 Template #}
{# Variables: group, selected_date, module_key, coarse_module, team_avg, lagging_agents, #}
{#             people_summary, strategy_summary, tool_summary, weak_case_stages, weak_principal_stages, module_avg_dial #}
{% macro fmt(v, d, suffix) -%}
{% if v is none or v is undefined %}--{% else %}{{ "%.#{d}f"|format(v) }}{{ suffix }}{% endif %}
{%- endmacro %}
{%- macro agent_row(a, idx) -%}
<div style="padding:6px 8px; border:1px solid #e5e7eb; border-radius:6px; margin-bottom:6px;">
    <b>#{{ idx + 1 }} {{ a.name }}</b> |
    Achv {{ fmt(a.achievement, 1, '%') }} |
    Attendance {{ fmt(a.attendance, 1, '%') }} |
    Dial {{ fmt(a.art_call_times, 0) }} |
    Connect {{ fmt(a.connect_rate, 1, '%') }} |
    Gap {{ fmt(a.gap, 0) }}
</div>
{%- endmacro %}

<div style="font-size:12px; color:#111827; line-height:1.5;">
    <div style="font-weight:700; margin-bottom:8px;">TL conclusion = group-level overview + lagging agents</div>
    <table style="width:100%; border-collapse:collapse; font-size:12px;">
        <tr style="background:#f8fafc;">
            <td style="border:1px solid #d1d5db; padding:8px; width:140px; font-weight:700;">维度 / Dimension</td>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">诊断 / Diagnosis</td>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700; width:260px;">建议行动 / Suggested Action</td>
        </tr>
        <tr style="background:#f8fafc;">
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">Group overview</td>
            <td style="border:1px solid #d1d5db; padding:8px;">
                Group: <b>{{ group }}</b> ({{ module_key or '--' }}) @ {{ selected_date }}<br>
                Achievement: <b>{{ fmt(team_avg.achievement, 1, '%') }}</b> | Attendance: <b>{{ fmt(team_avg.attendance, 1, '%') }}</b> | Dial: <b>{{ fmt(team_avg.art_call_times, 0) }}</b>
            </td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">持续监控本组核心指标，关注与模块均值的差距。</td>
        </tr>
        <tr>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">People factors</td>
            <td style="border:1px solid #d1d5db; padding:8px;">{{ people_summary }}</td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">
                {% if team_avg.attendance < 95 and team_avg.art_call_times < module_avg_dial %}
                排班核查：排查当日请假/缺勤原因，必要时启动临时调班或组内支援；同时约谈低产能人员，检查外呼系统分配与在线时长，排除系统故障。
                {% elif team_avg.attendance < 95 %}
                排班核查：排查当日请假/缺勤原因，必要时启动临时调班或组内支援。
                {% elif team_avg.art_call_times < module_avg_dial %}
                产能跟进：约谈低产能人员，检查外呼系统分配与在线时长，排除系统故障。
                {% else %}
                人员状态正常，维持现有排班与产能监控。
                {% endif %}
            </td>
        </tr>
        <tr>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">Strategy factors</td>
            <td style="border:1px solid #d1d5db; padding:8px;">
                {{ strategy_summary }}<br>
                Overdue stages with weak contribution: {{ weak_case_stages|join(', ') if weak_case_stages else '--' }}<br>
                Amount stages with weak contribution: {{ weak_principal_stages|join(', ') if weak_principal_stages else '--' }}
            </td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">
                {% if weak_case_stages and weak_principal_stages %}
                策略调整：优先加强 {{ weak_case_stages|join('、') }} 阶段跟进；同时对 {{ weak_principal_stages|join('、') }} 金额段提高分配权重或定制催收策略。
                {% elif weak_case_stages %}
                策略调整：优先加强 {{ weak_case_stages|join('、') }} 阶段跟进，检查对应话术覆盖与培训落地。
                {% elif weak_principal_stages %}
                金额聚焦：对 {{ weak_principal_stages|join('、') }} 金额段提高分配权重或定制催收策略。
                {% else %}
                阶段分布正常，维持现有策略。
                {% endif %}
            </td>
        </tr>
        <tr>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">Tool factors</td>
            <td style="border:1px solid #d1d5db; padding:8px;">{{ tool_summary }}</td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">
                {% if team_avg.connect_rate < 22 and team_avg.call_loss_rate > 20 %}
                通道检查：检查号码质量与线路稳定性，尝试调整拨打时段；同时排查接通后掉线原因（线路/网络/话术），优化首句留存率。
                {% elif team_avg.connect_rate < 22 %}
                通道检查：检查号码质量与线路稳定性，尝试调整拨打时段（如避开当地午休/通勤高峰）。
                {% elif team_avg.call_loss_rate > 20 %}
                掉线归因：排查接通后掉线原因（线路/网络/话术），优化首句留存率。
                {% else %}
                外呼通道稳定，保持当前线路配置。
                {% endif %}
            </td>
        </tr>
        <tr>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">Environment/other</td>
            <td style="border:1px solid #d1d5db; padding:8px;">If holiday/policy/system events occurred, use manual override for action priority.</td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">如确认有影响，请在改进方案中记录并调整优先级。</td>
        </tr>
        <tr>
            <td style="border:1px solid #d1d5db; padding:8px; font-weight:700;">Lagging agents</td>
            <td style="border:1px solid #d1d5db; padding:8px;">
                {% if not lagging_agents %}
                <div style="color:#6b7280;">No lagging agent identified for selected date.</div>
                {% else %}
                {% for agent in lagging_agents %}
                {{ agent_row(agent, loop.index0) }}
                {% endfor %}
                {% endif %}
            </td>
            <td style="border:1px solid #d1d5db; padding:8px; color:#065f46; background:#f0fdf4;">
                {% if not lagging_agents %}
                本组当日无落后人员，保持现有管理节奏。
                {% else %}
                逐个盯控：对落后人员启动一对一沟通，制定3-5天提升计划，每日复盘。
                {% endif %}
            </td>
        </tr>
    </table>
    {# Improvement plan doc-link (coarse_module already normalized in Python) #}
    {% if coarse_module %}
    {% set doc_urls = {
        'S0': 'https://doc.weixin.qq.com/sheet/e3_AGIATAbTANsCNWcq1Hf0CS76ZJaSp?scode=AGMA_AdxAAsSXn1aiyAGIATAbTANs&tab=BB08J2',
        'S1': 'https://doc.weixin.qq.com/sheet/e3_AGIATAbTANsCNKGdG4MPaQreE00Ga?scode=AGMA_AdxAAs8sEUIewAagA5gaoAKA&tab=BB08J2',
        'S2': 'https://doc.weixin.qq.com/sheet/e3_AGIATAbTANsCNk6txUBU0SG2hZ9A0?scode=AGMA_AdxAAs0D7crFlAagA5gaoAKA&tab=BB08J2',
        'M1': 'https://doc.weixin.qq.com/sheet/e3_AGIATAbTANsCNs8XAuzKHQmq0m0W1?scode=AGMA_AdxAAsARFwfuoAagA5gaoAKA&tab=BB08J2'
    } %}
    {% if coarse_module in doc_urls %}
    <div style="margin-top:10px; padding-top:10px; border-top:1px solid #e5e7eb; font-size:12px;">
        <div style="color:#374151; font-weight:600; margin-bottom:4px;">改进方案 · Improvement plan</div>
        <div style="color:#6b7280; font-size:11px; line-height:1.45; margin-bottom:6px;">
            在当前模块维度填写或跟踪改进动作（腾讯文档外链）。 / Fill in or track module-level improvement actions (Tencent Doc, external).
        </div>
        <a href="{{ doc_urls[coarse_module] }}" target="_blank" rel="noopener noreferrer" style="color:#2563eb;">
            打开「{{ coarse_module }}」模块改进方案 · Open {{ coarse_module }} improvement plan (Tencent Doc)
        </a>
    </div>
    {% endif %}
    {% endif %}
</div>
